DOCKER_API_APP_NAME=docker-api
DOCKER_API_ENVIRONMENT=development
DOCKER_API_DEBUG=false
DOCKER_API_API_PREFIX=/api/v1

# Upstream vya-workforce-api (hermes-agent em homologação). Se este serviço
# rodar na mesma rede Docker (app-network) que o stack docker_hermes, o
# hostname do container já resolve por nome.
DOCKER_API_VYA_API_BASE_URL=http://vya-workforce-api:8700
DOCKER_API_VYA_API_TIMEOUT_SECONDS=30

# VYA_API_KEY (sem prefixo DOCKER_API_) vem de Docker secret — ver
# .secrets/hermes/VYA_API_KEY (mesma credencial usada pela própria
# vya-workforce-api, não duplicar).
