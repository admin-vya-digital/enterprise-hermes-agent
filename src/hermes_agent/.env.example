# Copie para .env e ajuste os valores não sensíveis antes de subir o serviço.
# Nunca versionar o .env preenchido — apenas este .env.example.
#
# Segredos (VYA_API_KEY, ANTHROPIC_API_KEY, chaves de outros providers)
# NÃO vão aqui — ver .secrets/hermes/* na raiz do projeto e a seção
# "secrets:" do docker-compose.yaml. Detalhes no README.md deste diretório.

# Porta da API de provisionamento (vya-workforce-api)
VYA_PORT=8700

# Porta do dashboard web do Hermes Agent
HERMES_DASHBOARD_PORT=9119

# Para a lista completa e comentada de todas as variáveis suportadas pela
# aplicação hermes-agent (LLM providers opcionais, integrações de
# mensageria, terminal/sandbox, etc.), ver .env.example.original — este é
# o .env.example real do repositório hermes-agent, mantido aqui só como
# referência de consulta.
