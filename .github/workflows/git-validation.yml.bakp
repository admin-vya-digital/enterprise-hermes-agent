name: 🔍 Git Validation

on:
  pull_request:
    types: [opened, synchronize, reopened, edited]
  push:
    branches-ignore:
      - main
      - master
      - develop
      - staging
      - production

permissions:
  contents: read
  pull-requests: write
  statuses: write

jobs:
  validate-branch:
    name: Validate Branch Name
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: "pip"

      - name: Install dependencies
        run: |
          pip install --upgrade pip
          # Se tiver requirements, instalar: pip install -r requirements.txt

      - name: Validate branch name
        id: validate-branch
        run: |
          # Extrair nome da branch
          if [ "${{ github.event_name }}" == "pull_request" ]; then
            BRANCH_NAME="${{ github.head_ref }}"
          else
            BRANCH_NAME="${GITHUB_REF#refs/heads/}"
          fi

          echo "Branch name: $BRANCH_NAME"

          # Validar usando script Python
          python -c "
          import sys
          import re

          branch_name = '$BRANCH_NAME'

          # Pattern: tipo/[NNN-]descricao
          pattern = r'^(?:feature|fix|hotfix|chore|docs|refactor|test)/(?:\d+-)?[a-z0-9-]+$'

          if not re.match(pattern, branch_name):
              print(f'❌ Branch name inválido: {branch_name}')
              print()
              print('✅ Padrão esperado: tipo/[NNN-]descricao')
              print('   Tipos aceitos: feature, fix, hotfix, chore, docs, refactor, test')
              print('   Exemplos válidos:')
              print('     - feature/042-user-authentication')
              print('     - fix/memory-leak')
              print('     - docs/update-readme')
              sys.exit(1)

          print(f'✅ Branch name válido: {branch_name}')
          "

  validate-commits:
    name: Validate Commit Messages
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Validate commit messages
        run: |
          # Obter commits do PR ou push
          if [ "${{ github.event_name }}" == "pull_request" ]; then
            BASE="${{ github.event.pull_request.base.sha }}"
            HEAD="${{ github.event.pull_request.head.sha }}"
          else
            BASE="${{ github.event.before }}"
            HEAD="${{ github.sha }}"
          fi

          echo "Validating commits from $BASE to $HEAD"

          # Validar cada commit
          git log --format="%H %s" $BASE..$HEAD | while read sha message; do
            echo "Checking commit: $sha"
            echo "Message: $message"

            python -c "
          import sys
          import re

          message = '''$message'''

          # Pattern Conventional Commits: tipo(escopo): descrição
          pattern = r'^(?:feat|fix|docs|style|refactor|perf|test|chore|ci|build)(?:\([a-z0-9-]+\))?!?: .{3,}'

          if not re.match(pattern, message, re.IGNORECASE):
              print(f'❌ Commit message inválido: {message}')
              print()
              print('✅ Padrão esperado (Conventional Commits):')
              print('   tipo(escopo): descrição')
              print('   Tipos aceitos: feat, fix, docs, style, refactor, perf, test, chore, ci, build')
              print('   Exemplos válidos:')
              print('     - feat(api): add user endpoint')
              print('     - fix: memory leak in parser')
              print('     - docs(readme): update installation steps')
              sys.exit(1)

          print(f'✅ Commit message válido')
          "
          done

  validate-pr-title:
    name: Validate PR Title
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request'

    steps:
      - name: Validate PR title
        run: |
          PR_TITLE="${{ github.event.pull_request.title }}"
          echo "PR Title: $PR_TITLE"

          python -c "
          import sys
          import re

          title = '''$PR_TITLE'''

          # PR title deve seguir Conventional Commits
          pattern = r'^(?:feat|fix|docs|style|refactor|perf|test|chore|ci|build)(?:\([a-z0-9-]+\))?!?: .{3,}'

          if not re.match(pattern, title, re.IGNORECASE):
              print(f'❌ PR title inválido: {title}')
              print()
              print('✅ Padrão esperado (Conventional Commits):')
              print('   tipo(escopo): descrição')
              print()
              print('O título do PR deve seguir o mesmo padrão dos commits.')
              sys.exit(1)

          print(f'✅ PR title válido')
          "

  pr-size-check:
    name: Check PR Size
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request'

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Check PR size
        run: |
          # Contar linhas alteradas
          BASE="${{ github.event.pull_request.base.sha }}"
          HEAD="${{ github.event.pull_request.head.sha }}"

          ADDITIONS=$(git diff --numstat $BASE..$HEAD | awk '{sum+=$1} END {print sum}')
          DELETIONS=$(git diff --numstat $BASE..$HEAD | awk '{sum+=$2} END {print sum}')
          TOTAL=$((ADDITIONS + DELETIONS))
          FILES=$(git diff --name-only $BASE..$HEAD | wc -l)

          echo "📊 PR Statistics:"
          echo "   Additions: $ADDITIONS"
          echo "   Deletions: $DELETIONS"
          echo "   Total changes: $TOTAL"
          echo "   Files changed: $FILES"

          # Avisos baseados em tamanho
          if [ $TOTAL -gt 1000 ]; then
            echo "⚠️  WARNING: Large PR (>1000 lines). Consider breaking into smaller PRs."
            echo "::warning::PR is large ($TOTAL lines). Consider splitting into smaller changes."
          elif [ $TOTAL -gt 500 ]; then
            echo "⚠️  Medium PR ($TOTAL lines). Review may take longer."
          else
            echo "✅ PR size is reasonable ($TOTAL lines)."
          fi

          if [ $FILES -gt 20 ]; then
            echo "⚠️  WARNING: Many files changed ($FILES). Consider reducing scope."
            echo "::warning::Many files changed ($FILES). Consider reducing PR scope."
          fi

  summary:
    name: Validation Summary
    runs-on: ubuntu-latest
    needs: [validate-branch, validate-commits, validate-pr-title, pr-size-check]
    if: always()

    steps:
      - name: Check validation results
        run: |
          echo "🎯 Validation Summary:"
          echo "   Branch validation: ${{ needs.validate-branch.result }}"
          echo "   Commit validation: ${{ needs.validate-commits.result }}"
          echo "   PR title validation: ${{ needs.validate-pr-title.result }}"
          echo "   PR size check: ${{ needs.pr-size-check.result }}"

          if [ "${{ needs.validate-branch.result }}" != "success" ] || \
             [ "${{ needs.validate-commits.result }}" != "success" ] || \
             [ "${{ needs.validate-pr-title.result }}" != "success" ]; then
            echo "❌ Some validations failed. Please fix the issues above."
            exit 1
          fi

          echo "✅ All validations passed!"
